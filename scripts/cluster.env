# cluster.env

MASTER_HOST=de1-master
MASTER_IP=10.0.0.10            # private IP of the master VM

# Set 1..3 worker hostnames and IPs you actually have
WORKER_HOSTS=("de1-worker-1" "de1-worker-2" "de1-worker-3")
WORKER_IPS=("10.0.0.11" "10.0.0.12" "10.0.0.13")

# How many workers to start by default
DEFAULT_WORKER_COUNT=3

# Versions/paths
JAVA_PKG="openjdk-17-jdk"
HADOOP_VERSION="3.4.1"
SPARK_VERSION="4.1.1"
INSTALL_DIR="/opt"

# Data dirs
HDFS_NAME_DIR="/data/hdfs/namenode"
HDFS_DATA_DIR="/data/hdfs/datanode"

# HDFS/Spark settings
DFS_REPLICATION=2
SPARK_WORKER_MEMORY="2g"
SPARK_DRIVER_MEMORY="2g"
SPARK_EXECUTOR_MEMORY="2g"

# Security/SSH
SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
REMOTE_USER="ubuntu"

# Derived paths (no edit)
HADOOP_HOME="${INSTALL_DIR}/hadoop-${HADOOP_VERSION}"
SPARK_HOME="${INSTALL_DIR}/spark-${SPARK_VERSION}"
SPARK_MASTER_URL="spark://${MASTER_IP}:7077"
HDFS_NN_RPC="hdfs://${MASTER_IP}:9000"
``